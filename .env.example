# Copy this file to .env and fill in your values
# Never commit the .env file to version control

# Django secret key - generate a new one for production
# You can generate one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Set to True only for local development, never in production
DEBUG=False

# Comma-separated list of allowed hostnames (e.g. example.com,www.example.com)
ALLOWED_HOSTS=localhost,127.0.0.1
